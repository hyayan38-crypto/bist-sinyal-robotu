# Telegram
# 1. @BotFather'a /newbot yaz → token al
# 2. Botu gruba/kanala ekle → @userinfobot ile chat_id öğren
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Uygulama
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change_this_secret_key

# Veritabanı
DATABASE_URL=sqlite+aiosqlite:///./bist_robot.db

# Veri Ayarları
DEFAULT_SYMBOLS=THYAO.IS,ASELS.IS,KCHOL.IS,EREGL.IS,SISE.IS
DATA_INTERVAL=1d
DATA_PERIOD=2y

# Sinyal Ayarları
SIGNAL_CHECK_INTERVAL=300
MIN_SIGNAL_STRENGTH=0.6

# Risk Yönetimi
MAX_POSITION_SIZE=0.10
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
MAX_OPEN_SIGNALS=5
